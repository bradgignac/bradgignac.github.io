---
import { getCollection, render } from "astro:content";
import HikeLayout from "../../layouts/HikeLayout.astro";
import { getFeedItems, getNeighbors } from "../../utils/feed";

export async function getStaticPaths() {
  const [hikes, feedItems] = await Promise.all([
    getCollection("hikes"),
    getFeedItems(),
  ]);
  return hikes.map((hike) => ({
    params: { slug: hike.id },
    props: {
      hike,
      ...getNeighbors(feedItems, "hike", hike.id),
    },
  }));
}

const { hike, prev, next } = Astro.props;
const { Content } = await render(hike);
---

<HikeLayout
  title={hike.data.title}
  date={hike.data.date}
  alltrails_url={hike.data.alltrails_url}
  distance_miles={hike.data.distance_miles}
  elevation_gain_feet={hike.data.elevation_gain_feet}
  duration={hike.data.duration}
  tags={hike.data.tags}
  gear={hike.data.gear}
  prev={prev}
  next={next}
>
  <Content />
</HikeLayout>
