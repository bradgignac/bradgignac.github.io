---
import { getCollection, render } from "astro:content";
import HikeLayout from "../../layouts/HikeLayout.astro";

export async function getStaticPaths() {
  const hikes = await getCollection("hikes");
  return hikes.map((hike) => ({
    params: { slug: hike.id },
    props: { hike },
  }));
}

const { hike } = Astro.props;
const { Content } = await render(hike);
---

<HikeLayout
  title={hike.data.title}
  date={hike.data.date}
  alltrails_url={hike.data.alltrails_url}
  distance_miles={hike.data.distance_miles}
  elevation_gain_feet={hike.data.elevation_gain_feet}
  duration={hike.data.duration}
  tags={hike.data.tags}
  gear={hike.data.gear}
>
  <Content />
</HikeLayout>
