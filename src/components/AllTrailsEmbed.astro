---
interface Props {
  url: string;
  title?: string;
}

const { url, title = "AllTrails recording" } = Astro.props;
---

<iframe
  class="bg-alltrails-embed"
  src={url}
  width="100%"
  height="400"
  frameborder="0"
  scrolling="no"
  marginheight="0"
  marginwidth="0"
  title={title}
></iframe>
